  status        String    @default("pending") // pending, approved, paid
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  agent           InsuranceAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, status])
}

model RegulatoryReport {
  id              String    @id @default(cuid())
  tenantId        String
  reportType      String    // quarterly_statistical, annual_returns, claims_register, solvency, premium_register
  periodStart     DateTime?
  periodEnd       DateTime?
  data            String    @default("{}") // Full report data as JSON
  status          String    @default("draft") // draft, reviewed, submitted, rejected
