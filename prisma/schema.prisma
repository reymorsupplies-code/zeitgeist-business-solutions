}

model PriceSetting {
  id        String   @id @default(cuid())
  planId    String?
  key       String   @unique
  valueUSD  Decimal  @default(0) @db.Decimal(14, 2)
  valueTTD  Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt DateTime @updatedAt

  plan Plan? @relation(fields: [planId], references: [id])
}

// ============ PORTAL CUSTOMIZATION ============

model PortalSetting {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  portalName    String   @default("Tenant Portal")
  welcomeMsg    String   @default("Welcome to your portal")
  logoUrl       String?
  primaryColor  String   @default("#1e40af")
  accentColor   String   @default("#6366f1")
  bgColor       String   @default("#f8fafc")
  fontFamily    String   @default("inter")
  showPayments  Boolean  @default(true)
  showMaintenance Boolean @default(true)
  showDocuments Boolean  @default(true)
  allowChat     Boolean  @default(true)
  enabled       Boolean  @default(false)
  customDomain  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ LANDLORD / PROPERTY MANAGEMENT ============

model Property {
  id          String   @id @default(cuid())
  tenantId    String? // Multi-tenant scoping - links property to owning tenant
  name        String
  address     String?
  city        String?
  country     String   @default("TT")
  type        String   @default("commercial") // commercial, residential, mixed_use, office
  totalArea   Float? // sq ft
  units       Int      @default(1)
  description String?
  imageUrl    String?
  status      String   @default("active") // active, maintenance, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  propertyUnits       PropertyUnit[]
  maintenanceRequests MaintenanceRequest[]
  rentPayments        RentPayment[]
  vendors             PropertyVendor[]
  documents           PropertyDocument[]
  deposits            SecurityDeposit[]
  inspections         PropertyInspection[]
  legalNotices        LegalNotice[]
  ownerDisbursements  OwnerDisbursement[]
  renters             Renter[]

  @@index([tenantId])
}

model PropertyUnit {
  id          String   @id @default(cuid())
  propertyId  String
  unitNumber  String // e.g. "A1", "B2", "101"
  floor       Int      @default(1)
  area        Float? // sq ft
  baseRentTTD Decimal  @default(0) @db.Decimal(14, 2)
  baseRentUSD Decimal  @default(0) @db.Decimal(14, 2)
  tenantId    String? // nullable - unit can be vacant
  status      String   @default("vacant") // vacant, occupied, maintenance, reserved
  amenities   String   @default("[]")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id])
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  rentPayments        RentPayment[]
  documents           PropertyDocument[]
  deposits            SecurityDeposit[]
  inspections         PropertyInspection[]
  legalNotices        LegalNotice[]
  renters             Renter[]

  @@unique([propertyId, unitNumber])
}

model Lease {
  id                  String    @id @default(cuid())
  unitId              String
  tenantId            String?
  startDate           DateTime
  endDate             DateTime
  rentAmount          Decimal   @default(0) @db.Decimal(14, 2) // monthly
  rentCurrency        String    @default("TTD")
  depositAmount       Decimal   @default(0) @db.Decimal(14, 2)
  status              String    @default("active") // draft, active, expired, terminated, renewed
  terms               String?
  notes               String?
  // Renewal fields
  autoRenew           Boolean   @default(false)
  renewalNoticeDays   Int       @default(30) // days before end to send notice
  rentIncreasePercent Float     @default(0) // % increase on renewal
  lastRenewedAt       DateTime?
  renewalCount        Int       @default(0)
  originalStartDate   DateTime?
  originalEndDate     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  unit         PropertyUnit         @relation(fields: [unitId], references: [id])
  tenant       Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  rentPayments RentPayment[]
  documents    PropertyDocument[]
  deposits     SecurityDeposit[]
  inspections  PropertyInspection[]
  legalNotices LegalNotice[]
  renewalLogs  LeaseRenewalLog[]
  renters     Renter[]
  surchargeRecords SurchargeRecord[]

  @@index([tenantId, status])
  @@index([unitId, status])
}

model MaintenanceRequest {
  id          String    @id @default(cuid())
  propertyId  String
  unitId      String?
  tenantId    String?
  title       String
  description String?
  category    String? // plumbing, electrical, structural, hvac, general
  priority    String    @default("medium") // low, medium, high, urgent
  status      String    @default("open") // open, in_progress, resolved, closed
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?
  cost        Decimal   @default(0) @db.Decimal(14, 2)
  vendor      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  property Property      @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vendorId String?

  propertyVendor PropertyVendor? @relation(fields: [vendorId], references: [id])

  renters Renter[]

  @@index([tenantId, status])
  @@index([tenantId, propertyId])
}

// ============ PREMIUM LANDLORD FEATURES ===========

model RentPayment {
  id            String    @id @default(cuid())
  leaseId       String?
  propertyId    String
  unitId        String
  tenantId      String?
  periodStart   DateTime // billing period start
  periodEnd     DateTime // billing period end
  amountDue     Decimal   @default(0) @db.Decimal(14, 2)
  amountPaid    Decimal   @default(0) @db.Decimal(14, 2)
  lateFee       Decimal   @default(0) @db.Decimal(14, 2)
  currency      String    @default("TTD")
  paymentMethod String? // bank_transfer, cash, cheque, online
  paymentRef    String?
  status        String    @default("pending") // pending, partial, paid, late, overdue
  paidAt        DateTime?
  dueDate       DateTime
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lease    Lease?        @relation(fields: [leaseId], references: [id])
  property Property     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit @relation(fields: [unitId], references: [id])
  tenant   Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  renters  Renter[]

  @@index([tenantId, status, dueDate])
  @@index([tenantId, leaseId])
}

model PropertyVendor {
  id         String   @id @default(cuid())
  tenantId   String?
  propertyId String?
  name       String
  category   String? // plumbing, electrical, hvac, cleaning, landscaping, general, security, pest
  contact    String?
  email      String?
  phone      String?
  address    String?
  rating     Int      @default(0) // 1-5
  isActive   Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property            Property?            @relation(fields: [propertyId], references: [id])
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  maintenanceRequests MaintenanceRequest[]
}

model PropertyDocument {
  id          String    @id @default(cuid())
  propertyId  String?
  unitId      String?
  leaseId     String?
  tenantId    String?
  name        String
  type        String    @default("other") // lease_agreement, insurance, inspection, invoice, receipt, tax_doc, certificate, other
  category    String?
  fileUrl     String?
  description String?
  expiresAt   DateTime?
  status      String    @default("active") // active, expired, archived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  property Property?     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  lease    Lease?        @relation(fields: [leaseId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  renters  Renter[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  reference   String?
  status      String   @default("posted") // draft, posted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalEntryLine[]
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountCode    String
  accountName    String
  accountType    String // Asset, Liability, Equity, Revenue, Expense
  debit          Decimal  @default(0) @db.Decimal(14, 2)
  credit         Decimal  @default(0) @db.Decimal(14, 2)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
}

// ============ OWNER / INVESTOR REPORTING ============

model OwnerDisbursement {
  id                 String    @id @default(cuid())
  tenantId           String?
  propertyId         String?
  periodStart        DateTime
  periodEnd          DateTime
  grossIncome        Decimal   @default(0) @db.Decimal(14, 2)
  totalExpenses      Decimal   @default(0) @db.Decimal(14, 2)
  netIncome          Decimal   @default(0) @db.Decimal(14, 2)
  ownerShare         Float     @default(100) // percentage
  disbursementAmount Decimal   @default(0) @db.Decimal(14, 2)
  currency           String    @default("TTD")
  status             String    @default("pending") // pending, approved, paid
  paidAt             DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model LeaseRenewalLog {
  id          String   @id @default(cuid())
  tenantId    String?
  leaseId     String
  previousEnd DateTime
  newStart    DateTime
  newEnd      DateTime
  oldRent     Decimal  @default(0) @db.Decimal(14, 2)
  newRent     Decimal  @default(0) @db.Decimal(14, 2)
  increasePct Float    @default(0)
  renewedBy   String? // userId or 'auto'
  notes       String?
  createdAt   DateTime @default(now())

  lease  Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([leaseId])
}

// ============ T&T PROPERTY RENTAL COMPLIANCE ============

model SecurityDeposit {
  id              String    @id @default(cuid())
  leaseId         String
  propertyId      String
  unitId          String
  tenantId        String?
  amount          Decimal   @default(0) @db.Decimal(14, 2)
  currency        String    @default("TTD")
  status          String    @default("held") // held, partially_returned, fully_returned, deducted
  receivedDate    DateTime  @default(now())
  returnDeadline  DateTime // T&T law: 14 days after vacate
  returnedAmount  Decimal   @default(0) @db.Decimal(14, 2)
  returnedDate    DateTime?
  deductions      String    @default("[]") // JSON: [{description, amount, photoUrl, approvedAt}]
  deductionTotal  Decimal   @default(0) @db.Decimal(14, 2)
  refundMethod    String? // bank_transfer, cash, cheque
  refundReference String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lease    Lease        @relation(fields: [leaseId], references: [id])
  property Property     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit @relation(fields: [unitId], references: [id])
  tenant   Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  renters  Renter[]
}

model PropertyInspection {
  id               String   @id @default(cuid())
  propertyId       String
  unitId           String?
  leaseId          String?
  tenantId         String?
  type             String   @default("move_in") // move_in, move_out, routine, emergency
  inspectorName    String?
  inspectorRole    String?
  inspectedAt      DateTime @default(now())
  overallCondition String   @default("good") // excellent, good, fair, poor, damaged
  checklist        String   @default("[]") // JSON: [{area, item, condition, notes, photoUrl, score}]
  notes            String?
  scoreTotal       Int      @default(0)
  scoreMax         Int      @default(100)
  signedByTenant   Boolean  @default(false)
  signedByLandlord Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property Property?     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  lease    Lease?        @relation(fields: [leaseId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  renters  Renter[]
}

model LegalNotice {
  id            String    @id @default(cuid())
  leaseId       String?
  propertyId    String?
  unitId        String?
  tenantId      String?
  type          String // rent_increase, lease_renewal, lease_termination, eviction, late_payment, maintenance, vacate_notice
  jurisdiction  String    @default("TT") // TT, JM, BB, etc.
  templateSlug  String // links to notice template
  title         String
  content       String // full text of the legal notice
  sentDate      DateTime?
  sentMethod    String? // email, mail, hand_delivered, posted
  responseDate  DateTime?
  responseNotes String?
  status        String    @default("draft") // draft, sent, acknowledged, disputed, resolved, expired
  effectiveDate DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lease    Lease?        @relation(fields: [leaseId], references: [id])
  property Property?     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  tenant   Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  renters  Renter[]
}

// ============ RETAIL VAT COMPLIANCE (T&T BIR) ============

model VATReturn {
  id                String    @id @default(cuid())
  tenantId          String
  periodStart       DateTime
  periodEnd         DateTime
  quarter           String // Q1, Q2, Q3, Q4
  year              Int
  totalSalesExVAT   Decimal   @default(0) @db.Decimal(14, 2)
  totalVATCollected Decimal   @default(0) @db.Decimal(14, 2)
  totalVATPaid      Decimal   @default(0) @db.Decimal(14, 2)
  vatDue            Decimal   @default(0) @db.Decimal(14, 2)
  vatRefund         Decimal   @default(0) @db.Decimal(14, 2)
  birNumber         String?
  tin               String?
  vatRegNumber      String?
  status            String    @default("draft") // draft, filed, submitted, amended
  filedDate         DateTime?
  filedBy           String?
  receiptNumber     String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============ BAKERY FOOD SAFETY (HACCP / T&T Public Health) ============

model HACCPPlan {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  productCategory String? // bread, cake, pastry, dessert, etc.
  status          String    @default("draft") // draft, active, under_review, approved
  approvedBy      String?
  approvedAt      DateTime?
  criticalLimits  String    @default("[]") // JSON: [{ccpId, hazard, criticalLimit, monitoringProcedure, correctiveAction, record}]
  lastReviewDate  DateTime?
  nextReviewDate  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs   HACCPRiskLog[]
}

model HACCPRiskLog {
  id               String    @id @default(cuid())
  planId           String
  tenantId         String
  ccpName          String // Critical Control Point name
  hazardType       String? // biological, chemical, physical, allergen
  monitoringValue  String?
  criticalLimit    String?
  isWithinLimit    Boolean   @default(true)
  correctiveAction String?
  loggedBy         String?
  loggedAt         DateTime  @default(now())
  verifiedBy       String?
  verifiedAt       DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  plan   HACCPPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AllergenDeclaration {
  id           String   @id @default(cuid())
  tenantId     String
  recipeId     String?
  ingredientId String?
  productName  String
  allergens    String   @default("[]") // JSON: [{name, contains, level}] level: free, traces, contains
  lastReviewAt DateTime @default(now())
  reviewedBy   String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipe     Recipe?     @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
}

model FoodHandlerRegistration {
  id                 String    @id @default(cuid())
  tenantId           String
  employeeName       String
  employeeRole       String?
  registrationNumber String?
  registeredDate     DateTime?
  expiryDate         DateTime
  healthStatus       String    @default("active") // active, suspended, expired
  trainingDate       DateTime?
  certificateUrl     String?
  publicHealthDept   String    @default("County Medical Officer of Health")
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HealthInspection {
  id                 String    @id @default(cuid())
  tenantId           String
  inspectionDate     DateTime
  inspectorName      String?
  inspectorAgency    String    @default("Public Health Department")
  type               String    @default("routine") // routine, follow_up, complaint, pre_licensing
  overallScore       Int?
  scoreMax           Int       @default(100)
  result             String    @default("pass") // pass, pass_with_conditions, fail, pending
  violations         String    @default("[]") // JSON: [{code, description, severity, correctiveAction, dueDate, status}]
  correctiveActions  String    @default("[]") // JSON: [{action, assignedTo, dueDate, completedAt, notes}]
  nextInspectionDate DateTime?
  certificateUrl     String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TemperatureLog {
  id             String   @id @default(cuid())
  tenantId       String
  equipmentName  String
  equipmentType  String // oven, fridge, freezer, display_case, storage, delivery_vehicle
  location       String?
  temperature    Float
  unit           String   @default("C") // C or F
  isWithinRange  Boolean  @default(true)
  minSafe        Float?
  maxSafe        Float?
  loggedBy       String?
  loggedAt       DateTime @default(now())
  correctiveNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CleaningSanitationLog {
  id              String    @id @default(cuid())
  tenantId        String
  area            String // kitchen, storage, display, equipment, bathroom, general
  task            String
  cleaningProduct String?
  frequency       String    @default("daily") // after_each_use, daily, weekly, monthly
  completedBy     String?
  completedAt     DateTime  @default(now())
  verifiedBy      String?
  verifiedAt      DateTime?
  status          String    @default("completed") // completed, missed, rescheduled
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============ RENTER (Tenant Portal - Apartment Renter) ============
model Renter {
  id          String   @id @default(cuid())
  tenantId    String   // SaaS business tenant (property management company)
  leaseId     String?  // Current active lease
  unitId      String?  // Current unit
  propertyId  String?  // Current property
  fullName    String
  email       String
  phone       String?
  idDocument  String?  // National ID, passport, etc.
  pin         String   // 6-digit PIN for simple login (hashed)
  status      String   @default("active") // active, inactive, moved_out
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease     Lease?           @relation(fields: [leaseId], references: [id])
  unit      PropertyUnit?    @relation(fields: [unitId], references: [id])
  property  Property?        @relation(fields: [propertyId], references: [id])
  payments  RentPayment[]
  maintenanceRequests MaintenanceRequest[]
  deposits  SecurityDeposit[]
  inspections PropertyInspection[]
  documents PropertyDocument[]
  legalNotices LegalNotice[]

  @@index([tenantId])
  @@index([email])
  @@index([leaseId])
}

// ============ NOTIFICATION (In-App Notifications) ============
model Notification {
  id          String   @id @default(cuid())
  tenantId    String   // SaaS business tenant
  userId      String?  // Optional: specific PlatformUser
  renterId    String?  // Optional: specific Renter
  title       String
  message     String
  type        String   @default("info") // info, warning, success, error, rent_due, lease_expiring, maintenance, payment_received
  category    String   @default("general") // property, lease, payment, maintenance, legal, system
  link        String?  // Optional: page to navigate to when clicked
  isRead      Boolean  @default(false)
  readAt      DateTime?
  expiresAt   DateTime? // Auto-delete after this date
  metadata    String   @default("{}") // JSON: extra data
  createdAt   DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isRead])
  @@index([userId])
  @@index([renterId])
  @@index([createdAt])
}

// ============ PHASE 4: LANDLORD↔TENANT MESSAGING ============

model ChatConversation {
  id                String    @id @default(cuid())
  tenantId          String    // SaaS business tenant (property mgmt company)
  renterId          String?   // SQL is NOT NULL but kept optional for Prisma compat
  propertyId        String?   // Related property
  unitId            String?   // Related unit
  leaseId           String?   // Related lease
  subject           String?   // Conversation subject
  status            String    @default("active") // active, archived, closed
  lastMessageAt     DateTime? // Denormalized for list views
  lastMessagePreview String?
  lastMessageFrom   String?   // "landlord" or "renter"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([tenantId, lastMessageAt])
  @@index([renterId])
  @@index([propertyId])
  @@index([status])
}

model ChatMessage {
  id              String    @id @default(cuid())
  conversationId  String
  tenantId        String    // Tenant scoping
  senderType      String    // "landlord" or "renter"
  senderId        String?   // PlatformUser.id or Renter.id
  content         String
  messageType     String    @default("text") // text, image, document, system
  fileUrl         String?
  fileName        String?
  landlordReadAt  DateTime? // When landlord read this message
  renterReadAt    DateTime? // When renter read this message
  createdAt       DateTime  @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([tenantId])
  @@index([conversationId, senderType])
}

// ============ PHASE 7: LANDLORD SURCHARGE COMPLIANCE (T&T Jan 2026) ============

model SurchargeConfig {
  id              String    @id @default(cuid())
  tenantId        String    @unique // One config per tenant
  surchargeRate   Float     @default(0) // Surcharge rate as decimal (e.g. 0.05 = 5%)
  effectiveDate   DateTime  @default("2026-01-01T00:00:00Z")
  isApplicable    Boolean   @default(false) // Whether surcharge is being collected
  currency        String    @default("TTD")
  exemptions      String    @default("[]") // JSON array of exempt lease IDs or property types
  capAmount       Decimal?  @db.Decimal(14, 2) // Max surcharge per period (null = no cap)
  floorAmount     Decimal?  @db.Decimal(14, 2) // Min surcharge per period (null = no floor)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  records   SurchargeRecord[]

  @@index([tenantId])
}

model SurchargeRecord {
  id              String    @id @default(cuid())
  tenantId        String
  configId        String
  leaseId         String
  rentPaymentId   String?   // Link to rent payment if applicable
  propertyId      String
  unitId          String
  periodStart     DateTime
  periodEnd       DateTime
  periodLabel     String?   // e.g. "Jan 2026", "Q1 2026"
  baseRent        Decimal   @default(0) @db.Decimal(14, 2)
  surchargeRate   Float     @default(0)
  surchargeAmount Decimal   @default(0) @db.Decimal(14, 2)
  capAmount       Decimal?  @db.Decimal(14, 2)
  floorAmount     Decimal?  @db.Decimal(14, 2)
  currency        String    @default("TTD")
  status          String    @default("pending") // pending, collected, waived, overdue, remitted
  exemptionReason String?   // Reason for waiver/exemption (API reference, add to SQL later)
  collectedAt     DateTime?
  remittedAt      DateTime? // When remitted to BIR
  remittanceRef   String?   // BIR remittance reference
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  config       SurchargeConfig @relation(fields: [configId], references: [id])
  lease        Lease           @relation(fields: [leaseId], references: [id])

  @@unique([leaseId, periodStart, periodEnd])
  @@index([tenantId, periodStart])
  @@index([leaseId])
  @@index([configId])
  @@index([propertyId])
  @@index([tenantId, status])
}

// ============ PHASE 9: WiPay PAYMENT TRANSACTIONS ============

model WiPayTransaction {
  id                  String    @id @default(cuid())
  tenantId            String
  rentPaymentId       String?   // Link to RentPayment if applicable
  renterId            String?   // Renter who initiated the payment
  paymentMethod       String    @default("wipay") // wipay (online) or cash (manual recording)
  status              String    @default("initiated") // initiated, processing, completed, failed, refunded, expired
  amount              Decimal   @default(0) @db.Decimal(14, 2)
  currency            String    @default("TTD")
  processingFee       Decimal   @default(0) @db.Decimal(14, 2)
  wipayOrderId        String?   // WiPay order reference
  wipayTransactionId  String?   @unique // Unique WiPay transaction ID
  wipayFee            Decimal   @default(0) @db.Decimal(14, 2) // Fee charged by WiPay
  wipayCurrency       String?   // Currency returned by WiPay
  cardType            String?   // visa, mastercard, etc.
  cardLast4           String?   // Last 4 digits of card
  customerName        String?   // Customer name snapshot
  customerEmail       String?   // Customer email snapshot
  customerPhone       String?   // Customer phone snapshot
  cashReference       String?   // Receipt number when paymentMethod is cash
  cashNotes           String?   // Notes from landlord or renter
  refundAmount        Decimal   @default(0) @db.Decimal(14, 2)
  refundReason        String?
  refundedAt          DateTime?
  ipAddress           String?   // For fraud audit
  initiatedAt         DateTime  @default(now())
  completedAt         DateTime?
  webhookData         String?   @db.Text // Raw webhook response from WiPay
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId])
  @@index([rentPaymentId])
  @@index([renterId])
  @@index([status])
  @@index([tenantId, status])
  @@index([tenantId, paymentMethod])
  @@index([tenantId, createdAt])
}

// ============ PHASE 10: TENANT SCREENING / APPLICATION ============

model TenantApplication {
  id              String    @id @default(cuid())
  tenantId        String    // Property mgmt company
  propertyId      String?
  unitId          String?
  status          String    @default("pending") // pending, reviewing, approved, rejected, withdrawn, waitlisted
  // Applicant personal info
  firstName       String
  lastName        String
  email           String
  phone           String?
  dateOfBirth     DateTime?
  nationalId      String?   // T&T national ID or passport
  // Employment & income
  employer        String?
  jobTitle        String?
  monthlyIncome   Decimal?  @db.Decimal(14, 2)
  employmentLength String?
  // Rental history
  previousAddress String?
  previousLandlordName String?
  previousLandlordPhone String?
  reasonForLeaving String?
  // References
  reference1Name  String?
  reference1Phone String?
  reference1Email String?
  reference2Name  String?
  reference2Phone String?
  reference2Email String?
  // Screening results
  screeningScore  Int?      // 0-100
  riskLevel       String?   // low, medium, high
  screeningNotes  String?
  backgroundCheckStatus String @default("not_started") // not_started, in_progress, completed, failed
  // Documents
  idDocumentUrl   String?
  incomeProofUrl  String?
  employmentLetterUrl String?
  // Preferences
  desiredMoveInDate DateTime?
  leaseTermPreference String? // 6_months, 1_year, 2_years
  numberOfOccupants Int?
  hasPets         Boolean   @default(false)
  petDescription  String?
  // Review
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([email])
  @@index([unitId])
  @@index([propertyId])
  @@index([status])
  @@index([tenantId, createdAt])
}

