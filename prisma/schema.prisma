generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ PLATFORM MODELS ============

model PlatformUser {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  fullName     String?
  role         String    @default("tenant_admin")
  avatarUrl    String?
  isActive     Boolean   @default(true)
  hasUsedTrial Boolean   @default(false)
  lastActiveAt DateTime?
  country      String?
  timezone     String?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resetToken     String?
  resetTokenExpiry DateTime?

  tenantMemberships TenantMembership[]
  auditLogs         AuditLog[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  tier             String   @default("starter")
  priceUSD         Decimal  @default(0) @db.Decimal(14, 2)
  priceTTD         Decimal  @default(0) @db.Decimal(14, 2)
  currency         String   @default("TTD")
  billingCycle     String   @default("monthly")
  tagline          String?
  description      String?
  idealFor         String?
  maxUsers         Int      @default(3)
  maxBranches      Int      @default(1)
  features         String   @default("[]")
  excludedFeatures String   @default("[]")
  isPopular        Boolean  @default(false)
  status           String   @default("active")
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenants       Tenant[]
  subscriptions TenantSubscription[]
  priceSettings PriceSetting[]
}

model Tenant {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  logoUrl           String?
  industryId        String?
  planId            String?
  planName          String?
  status            String    @default("trial")
  trialStartsAt     DateTime?
  trialEndsAt       DateTime?
  hasUsedTrial      Boolean   @default(false)
  trialDurationDays Int       @default(7)
  approvedBy        String?
  approvedAt        DateTime?
  paymentVerified   Boolean   @default(false)
  lastActivityAt    DateTime?
  registrationIp    String?
  primaryColor      String    @default("#1D4ED8")
  accentColor       String    @default("#2563EB")
  currency          String    @default("TTD")
  timezone          String    @default("America/Port_of_Spain")
  locale            String    @default("en")
  taxRate           Float     @default(0.125)
  country           String    @default("TT")
  address           String?
  phone             String?
  email             String?
  website           String?
  settings          String    @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  industry                 Industry?                 @relation(fields: [industryId], references: [id])
  plan                     Plan?                     @relation(fields: [planId], references: [id])
  memberships              TenantMembership[]
  orders                   Order[]
  catalogItems             CatalogItem[]
  clients                  Client[]
  invoices                 Invoice[]
  quotations               Quotation[]
  payments                 Payment[]
  expenses                 Expense[]
  recipes                  Recipe[]
  ingredients              Ingredient[]
  designGallery            DesignItem[]
  appointments             Appointment[]
  stylists                 Stylist[]
  salonServices            SalonServiceItem[]
  subscriptions            TenantSubscription[]
  featureFlags             TenantFeatureFlag[]
  documents                TenantDocument[]
  bookkeepingEntries       BookkeepingEntry[]
  auditLogs                AuditLog[]
  patients                 Patient[]
  medicalAppointments      MedicalAppointment[]
  legalCases               LegalCase[]
  timeEntries              TimeEntry[]
  policies                 Policy[]
  claims                   Claim[]
  retailProducts           RetailProduct[]
  purchaseOrders           PurchaseOrder[]
  posSales                 POSSale[]
  suppliers                Supplier[]
  stockMovements           StockMovement[]
  layaways                 Layaway[]
  events                   Event[]
  venues                   Venue[]
  vendors                  Vendor[]
  projects                 Project[]
  contracts                Contract[]
  propertyUnits            PropertyUnit[]
  leases                   Lease[]
  maintenanceRequests      MaintenanceRequest[]
  rentPayments             RentPayment[]
  propertyDocuments        PropertyDocument[]
  loyaltyMembers           LoyaltyMember[]
  loyaltyTransactions      LoyaltyTransaction[]      @relation("LoyaltyTransactionTenant")
  giftCards                GiftCard[]
  productReturns           ProductReturn[]
  registerShifts           RegisterShift[]
  securityDeposits         SecurityDeposit[]
  propertyInspections      PropertyInspection[]
  legalNotices             LegalNotice[]
  vatReturns               VATReturn[]
  haccpPlans               HACCPPlan[]
  haccpRiskLogs            HACCPRiskLog[]
  allergenDeclarations     AllergenDeclaration[]
  foodHandlerRegistrations FoodHandlerRegistration[]
  healthInspections        HealthInspection[]
  temperatureLogs          TemperatureLog[]
  cleaningLogs             CleaningSanitationLog[]
  properties               Property[]
  ownerDisbursements       OwnerDisbursement[]
  leaseRenewalLogs         LeaseRenewalLog[]
  propertyVendors          PropertyVendor[]
  systemEvents             SystemEvent[]
  platformInvoices         PlatformInvoice[]
  renters                  Renter[]
  notifications            Notification[]
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("admin")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   PlatformUser @relation(fields: [userId], references: [id])
  tenant Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model TenantFeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  featureSlug String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureSlug])
}

model TenantSubscription {
  id                 String    @id @default(cuid())
  tenantId           String
  planId             String?
  planName           String?
  status             String    @default("active")
  billingCycle       String    @default("monthly")
  priceUSD           Decimal   @default(0) @db.Decimal(14, 2)
  priceTTD           Decimal   @default(0) @db.Decimal(14, 2)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paymentBehavior    String    @default("always_on_time")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan?  @relation(fields: [planId], references: [id])
}

// ============ BAKERY MODELS ============

model Order {
  id              String    @id @default(cuid())
  tenantId        String
  orderNumber     String?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  items           String    @default("[]")
  subtotal        Decimal   @default(0) @db.Decimal(14, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal   @default(0) @db.Decimal(14, 2)
  status          String    @default("pending")
  orderType       String    @default("custom")
  deliveryDate    DateTime?
  deliveryAddress String?
  notes           String?
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model CatalogItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  price       Decimal  @default(0) @db.Decimal(14, 2)
  cost        Decimal  @default(0) @db.Decimal(14, 2)
  unit        String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  tags      String   @default("[]")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  loyaltyMembers LoyaltyMember[]

  @@index([tenantId])
}

model Invoice {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceNumber String?
  clientName    String?
  clientEmail   String?
  items         String    @default("[]")
  subtotal      Decimal   @default(0) @db.Decimal(14, 2)
  taxRate       Float     @default(0)
  taxAmount     Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(14, 2)
  balanceDue    Decimal   @default(0) @db.Decimal(14, 2)
  status        String    @default("draft")
  issueDate     DateTime?
  dueDate       DateTime?
  notes         String?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([tenantId])
}

model Quotation {
  id          String    @id @default(cuid())
  tenantId    String
  quoteNumber String?
  clientName  String?
  clientEmail String?
  clientPhone String?
  items       String    @default("[]")
  subtotal    Decimal   @default(0) @db.Decimal(14, 2)
  discount    Decimal   @default(0) @db.Decimal(14, 2)
  taxRate     Float     @default(0)
  taxAmount   Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount Decimal   @default(0) @db.Decimal(14, 2)
  status      String    @default("draft")
  validUntil  DateTime?
  notes       String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String?
  amount    Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("TTD")
  method    String   @default("cash")
  reference String?
  status    String   @default("completed")
  notes     String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Expense {
  id          String    @id @default(cuid())
  tenantId    String
  category    String?
  description String?
  amount      Decimal   @default(0) @db.Decimal(14, 2)
  currency    String    @default("TTD")
  date        DateTime?
  receiptUrl  String?
  vendor      String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Recipe {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  category       String?
  servings       Int?
  prepTime       Int?
  cookTime       Int?
  ingredients    String   @default("[]")
  instructions   String   @default("[]")
  costPerServing Decimal  @default(0) @db.Decimal(14, 2)
  sellingPrice   Decimal  @default(0) @db.Decimal(14, 2)
  imageUrl       String?
  isPublic       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  allergenDeclarations AllergenDeclaration[]

  @@index([tenantId])
}

model Ingredient {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String?
  unit        String?
  costPerUnit Decimal  @default(0) @db.Decimal(14, 2)
  quantity    Float    @default(0)
  minStock    Float    @default(0)
  supplier    String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  allergenDeclarations AllergenDeclaration[]
  stockMovements       StockMovement[]

  @@index([tenantId])
}

model DesignItem {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  category    String?
  imageUrl    String?
  tags        String   @default("[]")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model TenantDocument {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String   @default("general")
  content   String?
  fileUrl   String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ============ SALON MODELS ============

model Appointment {
  id         String    @id @default(cuid())
  tenantId   String
  clientName String?
  stylistId  String?
  serviceId  String?
  date       DateTime?
  duration   Int       @default(60)
  status     String    @default("scheduled")
  notes      String?
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  stylist Stylist?          @relation(fields: [stylistId], references: [id])
  service SalonServiceItem? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
}

model Stylist {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  specialty String?
  phone     String?
  email     String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId])
}

model SalonServiceItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  duration    Int      @default(60)
  price       Decimal  @default(0) @db.Decimal(14, 2)
  category    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId])
}

// ============ CLINIC MODELS ============

model Patient {
  id                  String               @id @default(cuid())
  tenantId            String
  firstName           String
  lastName            String
  dateOfBirth         DateTime?
  gender              String?
  email               String?
  phone               String?
  address             String?
  bloodType           String?
  allergies           String               @default("[]")
  medicalNotes        String?
  insuranceProvider   String?
  insuranceNumber     String?
  emergencyContact    String?
  emergencyPhone      String?
  isDeleted           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  medicalAppointments MedicalAppointment[]

  @@index([tenantId])
}

model MedicalAppointment {
  id           String    @id @default(cuid())
  tenantId     String
  patientId    String?
  doctorName   String?
  specialty    String?
  date         DateTime?
  duration     Int       @default(30)
  status       String    @default("scheduled")
  notes        String?
  diagnosis    String?
  prescription String?
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  patient      Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ============ LEGAL MODELS ============

model LegalCase {
  id          String      @id @default(cuid())
  tenantId    String
  caseNumber  String?
  title       String
  clientName  String?
  caseType    String?
  status      String      @default("open")
  court       String?
  judge       String?
  openDate    DateTime?
  closeDate   DateTime?
  description String?
  billingRate Decimal     @default(0) @db.Decimal(14, 2)
  hoursBilled Float       @default(0)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  timeEntries TimeEntry[]

  @@index([tenantId])
}

model TimeEntry {
  id          String     @id @default(cuid())
  tenantId    String
  caseId      String?
  description String
  duration    Int        @default(0)
  billingRate Decimal    @default(0) @db.Decimal(14, 2)
  billable    Boolean    @default(true)
  date        DateTime?
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  legalCase   LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ============ INSURANCE MODELS ============

model Policy {
  id            String    @id @default(cuid())
  tenantId      String
  policyNumber  String?
  clientName    String?
  type          String?
  premium       Decimal   @default(0) @db.Decimal(14, 2)
  coverage      Decimal   @default(0) @db.Decimal(14, 2)
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("active")
  beneficiaries String    @default("[]")
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  claims        Claim[]

  @@index([tenantId])
}

model Claim {
  id           String    @id @default(cuid())
  tenantId     String
  policyId     String?
  claimNumber  String?
  claimantName String?
  type         String?
  amount       Decimal   @default(0) @db.Decimal(14, 2)
  status       String    @default("submitted")
  incidentDate DateTime?
  description  String?
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  policy       Policy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ============ RETAIL MODELS ============

model RetailProduct {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  sku         String?
  category    String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  cost        Decimal  @default(0) @db.Decimal(12, 2)
  quantity    Int      @default(0)
  minStock    Int      @default(0)
  supplier    String?
  barcode     String?
  imageUrl    String?
  taxCategory String   @default("standard") // standard (12.5%), exempt, zero_rated — T&T VAT
  settings    String   @default("{}")
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isDeleted])
  @@index([tenantId, barcode])
}

// ============ LAYAWAY (APARTADOS) ============

model Layaway {
  id                String    @id @default(cuid())
  tenantId          String
  layawayNumber     String
  customerName      String
  customerPhone     String
  customerEmail     String?
  items             String    @default("[]") // JSON: [{productId, name, sku, barcode, quantity, unitPrice, lineTotal}]
  totalAmount       Decimal   @default(0) @db.Decimal(12, 2)
  depositAmount     Decimal   @default(0) @db.Decimal(12, 2)
  balanceRemaining  Decimal   @default(0) @db.Decimal(12, 2)
  payments          String    @default("[]") // JSON: [{date, amount, method, reference}]
  status            String    @default("active") // active, completed, cancelled, expired
  dueDate           DateTime?
  expiryDate        DateTime
  depositPercentage Decimal   @default(20) @db.Decimal(12, 2)
  notes             String?
  isDeleted         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, layawayNumber])
}

// ============ STOCK MOVEMENT ============

model StockMovement {
  id            String    @id @default(cuid())
  tenantId      String
  ingredientId  String?
  type          String
  quantity      Decimal   @default(0) @db.Decimal(12, 2)
  previousStock Decimal   @default(0) @db.Decimal(12, 2)
  newStock      Decimal   @default(0) @db.Decimal(12, 2)
  unitCost      Decimal   @default(0) @db.Decimal(12, 2)
  reason        String?
  reference     String?
  batchNumber   String?
  expiryDate    DateTime?
  method        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([tenantId, type])
  @@map("StockMovement")
}

// ============ PURCHASE ORDER ============

model PurchaseOrder {
  id             String    @id @default(cuid())
  tenantId       String
  poNumber       String
  supplierId     String?
  supplierName   String
  status         String    @default("draft") // draft, sent, partial, received, cancelled
  items          String    @default("[]") // JSON: [{productId, name, sku, qty, unitCost, receivedQty}]
  totalAmount    Decimal   @default(0) @db.Decimal(12, 2)
  receivedAmount Decimal   @default(0) @db.Decimal(12, 2)
  notes          String?
  expectedDate   DateTime?
  receivedAt     DateTime?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([tenantId, poNumber])
}

// ============ POS SALE ============

model POSSale {
  id             String          @id @default(cuid())
  tenantId       String
  saleNumber     String
  items          String          @default("[]") // JSON: [{productId, name, sku, qty, price, cost}]
  subtotal       Decimal         @default(0) @db.Decimal(12, 2)
  discountPct    Decimal         @default(0) @db.Decimal(12, 2)
  discountAmount Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal         @default(0) @db.Decimal(12, 2)
  taxRate        Decimal         @default(0.125) @db.Decimal(5, 4) // VAT rate applied (default 12.5% T&T)
  totalAmount    Decimal         @default(0) @db.Decimal(12, 2)
  paymentMethod  String          @default("cash") // cash, card, transfer, gift_card, split
  giftCardId     String? // Reference to gift card used for payment
  splitDetails   String?         @default("") // JSON: {cash, card, giftCard, transfer, giftCardId}
  cashReceived   Decimal         @default(0) @db.Decimal(12, 2)
  changeAmount   Decimal         @default(0) @db.Decimal(12, 2)
  currency       String          @default("TTD")
  customerName   String          @default("")
  staffName      String?
  status         String          @default("completed") // completed, held, voided
  isDeleted      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  giftCard       GiftCard?       @relation(fields: [giftCardId], references: [id])
  productReturns ProductReturn[]

  @@unique([tenantId, saleNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

// ============ GIFT CARDS ============

model GiftCard {
  id             String    @id @default(cuid())
  tenantId       String
  cardNumber     String
  cardCode       String
  initialBalance Decimal   @default(0) @db.Decimal(12, 2)
  currentBalance Decimal   @default(0) @db.Decimal(12, 2)
  customerName   String?
  purchaserName  String
  status         String    @default("active") // active, used, expired, voided
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  transactions   String    @default("[]") // JSON: [{date, type, amount, reference, saleId?}]
  notes          String?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posSales POSSale[]

  @@unique([tenantId, cardNumber])
  @@unique([tenantId, cardCode])
}

// ============ RETURNS & EXCHANGES ============

model ProductReturn {
  id           String   @id @default(cuid())
  tenantId     String
  saleId       String
  returnNumber String
  items        String   @default("[]") // JSON: [{productId, name, quantity, unitPrice, reason}]
  totalRefund  Decimal  @default(0) @db.Decimal(12, 2)
  refundMethod String   @default("cash") // cash, card, storeCredit, transfer
  reason       String   @default("other") // defective, wrongItem, changedMind, damaged, other
  status       String   @default("pending") // pending, approved, rejected, completed
  processedBy  String?
  notes        String?
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, returnNumber])
  @@map("ProductReturn")
}

// ============ REGISTER SHIFT (CIERRE DE CAJA) ============

model RegisterShift {
  id               String    @id @default(cuid())
  tenantId         String
  shiftNumber      String
  staffName        String
  staffId          String?
  openedAt         DateTime  @default(now())
  closedAt         DateTime?
  status           String    @default("open") // open, closed
  startingCash     Decimal   @default(0) @db.Decimal(12, 2)
  closingCash      Decimal?  @db.Decimal(12, 2)
  expectedCash     Decimal?  @db.Decimal(12, 2)
  cashSales        Decimal   @default(0) @db.Decimal(12, 2)
  cardSales        Decimal   @default(0) @db.Decimal(12, 2)
  transferSales    Decimal   @default(0) @db.Decimal(12, 2)
  totalSales       Decimal   @default(0) @db.Decimal(12, 2)
  totalRefunds     Decimal   @default(0) @db.Decimal(12, 2)
  giftCardSales    Decimal   @default(0) @db.Decimal(12, 2)
  layawayDeposits  Decimal   @default(0) @db.Decimal(12, 2)
  transactionCount Int       @default(0)
  refundCount      Int       @default(0)
  discrepancy      Decimal?  @db.Decimal(12, 2)
  notes            String?
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shiftNumber])
  @@index([tenantId, status])
}

