generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ PLATFORM MODELS ============

model PlatformUser {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  fullName     String?
  role         String    @default("tenant_admin")
  avatarUrl    String?
  isActive     Boolean   @default(true)
  hasUsedTrial Boolean   @default(false)
  lastActiveAt DateTime?
  country      String?
  timezone     String?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resetToken     String?
  resetTokenExpiry DateTime?

  tenantMemberships TenantMembership[]
  auditLogs         AuditLog[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  tier             String   @default("starter")
  priceUSD         Decimal  @default(0) @db.Decimal(14, 2)
  priceTTD         Decimal  @default(0) @db.Decimal(14, 2)
  currency         String   @default("TTD")
  billingCycle     String   @default("monthly")
  tagline          String?
  description      String?
  idealFor         String?
  maxUsers         Int      @default(3)
  maxBranches      Int      @default(1)
  features         String   @default("[]")
  excludedFeatures String   @default("[]")
  isPopular        Boolean  @default(false)
  status           String   @default("active")
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenants       Tenant[]
  subscriptions TenantSubscription[]
  priceSettings PriceSetting[]
}

model Tenant {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  logoUrl           String?
  industryId        String?
  planId            String?
  planName          String?
  status            String    @default("trial")
  trialStartsAt     DateTime?
  trialEndsAt       DateTime?
  hasUsedTrial      Boolean   @default(false)
  trialDurationDays Int       @default(7)
  approvedBy        String?
  approvedAt        DateTime?
  paymentVerified   Boolean   @default(false)
  lastActivityAt    DateTime?
  registrationIp    String?
  primaryColor      String    @default("#1D4ED8")
  accentColor       String    @default("#2563EB")
  currency          String    @default("TTD")
  timezone          String    @default("America/Port_of_Spain")
  locale            String    @default("en")
  taxRate           Float     @default(0.125)
  country           String    @default("TT")
  address           String?
  phone             String?
  email             String?
  website           String?
  settings          String    @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  industry                 Industry?                 @relation(fields: [industryId], references: [id])
  plan                     Plan?                     @relation(fields: [planId], references: [id])
  memberships              TenantMembership[]
  orders                   Order[]
  catalogItems             CatalogItem[]
  clients                  Client[]
  invoices                 Invoice[]
  quotations               Quotation[]
  payments                 Payment[]
  expenses                 Expense[]
  recipes                  Recipe[]
  ingredients              Ingredient[]
  designGallery            DesignItem[]
  appointments             Appointment[]
  stylists                 Stylist[]
  salonServices            SalonServiceItem[]
  subscriptions            TenantSubscription[]
  featureFlags             TenantFeatureFlag[]
  documents                TenantDocument[]
  bookkeepingEntries       BookkeepingEntry[]
  auditLogs                AuditLog[]
  patients                 Patient[]
  medicalAppointments      MedicalAppointment[]
  legalCases               LegalCase[]
  timeEntries              TimeEntry[]
  policies                 Policy[]
  claims                   Claim[]
  insureds                 Insured[]
  insuranceAgents          InsuranceAgent[]
  insuranceProducts        InsuranceProduct[]
  quotes                   Quote[]
  quoteLines               QuoteLine[]
  claimDocuments           ClaimDocument[]
  claimNotes               ClaimNote[]
  claimActivities          ClaimActivity[]
  endorsements             Endorsement[]
  premiumSchedules         PremiumSchedule[]
  renewalTasks             RenewalTask[]
  portalTokens             PortalToken[]
  underwritingRules        UnderwritingRule[]
  commissionStatements     CommissionStatement[]
  regulatoryReports        RegulatoryReport[]
  retailProducts           RetailProduct[]
  purchaseOrders           PurchaseOrder[]
  posSales                 POSSale[]
  suppliers                Supplier[]
  stockMovements           StockMovement[]
  layaways                 Layaway[]
  events                   Event[]
  venues                   Venue[]
  vendors                  Vendor[]
  projects                 Project[]
  contracts                Contract[]
  propertyUnits            PropertyUnit[]
  leases                   Lease[]
  maintenanceRequests      MaintenanceRequest[]
  rentPayments             RentPayment[]
  propertyDocuments        PropertyDocument[]
  loyaltyMembers           LoyaltyMember[]
  loyaltyTransactions      LoyaltyTransaction[]      @relation("LoyaltyTransactionTenant")
  giftCards                GiftCard[]
  productReturns           ProductReturn[]
  registerShifts           RegisterShift[]
  securityDeposits         SecurityDeposit[]
  propertyInspections      PropertyInspection[]
  legalNotices             LegalNotice[]
  vatReturns               VATReturn[]
  haccpPlans               HACCPPlan[]
  haccpRiskLogs            HACCPRiskLog[]
  allergenDeclarations     AllergenDeclaration[]
  foodHandlerRegistrations FoodHandlerRegistration[]
  healthInspections        HealthInspection[]
  temperatureLogs          TemperatureLog[]
  cleaningLogs             CleaningSanitationLog[]
  properties               Property[]
  ownerDisbursements       OwnerDisbursement[]
  leaseRenewalLogs         LeaseRenewalLog[]
  propertyVendors          PropertyVendor[]
  systemEvents             SystemEvent[]
  platformInvoices         PlatformInvoice[]
  renters                  Renter[]
  notifications            Notification[]
  chatConversations        ChatConversation[]
  surchargeConfigs         SurchargeConfig[]
  surchargeRecords         SurchargeRecord[]
  portalSettings            PortalSetting?
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("admin")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   PlatformUser @relation(fields: [userId], references: [id])
  tenant Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model TenantFeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  featureSlug String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureSlug])
}

model TenantSubscription {
  id                 String    @id @default(cuid())
  tenantId           String
  planId             String?
  planName           String?
  status             String    @default("active")
  billingCycle       String    @default("monthly")
  priceUSD           Decimal   @default(0) @db.Decimal(14, 2)
  priceTTD           Decimal   @default(0) @db.Decimal(14, 2)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paymentBehavior    String    @default("always_on_time")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan?  @relation(fields: [planId], references: [id])
}

// ============ BAKERY MODELS ============

model Order {
  id              String    @id @default(cuid())
  tenantId        String
  orderNumber     String?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  items           String    @default("[]")
  subtotal        Decimal   @default(0) @db.Decimal(14, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal   @default(0) @db.Decimal(14, 2)
  status          String    @default("pending")
  orderType       String    @default("custom")
  deliveryDate    DateTime?
  deliveryAddress String?
  notes           String?
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model CatalogItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  price       Decimal  @default(0) @db.Decimal(14, 2)
  cost        Decimal  @default(0) @db.Decimal(14, 2)
  unit        String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  tags      String   @default("[]")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  loyaltyMembers LoyaltyMember[]

  @@index([tenantId])
}

model Invoice {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceNumber String?
  clientName    String?
  clientEmail   String?
  items         String    @default("[]")
  subtotal      Decimal   @default(0) @db.Decimal(14, 2)
  taxRate       Float     @default(0)
  taxAmount     Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(14, 2)
  balanceDue    Decimal   @default(0) @db.Decimal(14, 2)
  status        String    @default("draft")
  issueDate     DateTime?
  dueDate       DateTime?
  notes         String?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([tenantId])
}

model Quotation {
  id          String    @id @default(cuid())
  tenantId    String
  quoteNumber String?
  clientName  String?
  clientEmail String?
  clientPhone String?
  items       String    @default("[]")
  subtotal    Decimal   @default(0) @db.Decimal(14, 2)
  discount    Decimal   @default(0) @db.Decimal(14, 2)
  taxRate     Float     @default(0)
  taxAmount   Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount Decimal   @default(0) @db.Decimal(14, 2)
  status      String    @default("draft")
  validUntil  DateTime?
  notes       String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String?
  amount    Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("TTD")
  method    String   @default("cash")
  reference String?
  status    String   @default("completed")
  notes     String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Expense {
  id          String    @id @default(cuid())
  tenantId    String
  category    String?
  description String?
  amount      Decimal   @default(0) @db.Decimal(14, 2)
  currency    String    @default("TTD")
  date        DateTime?
  receiptUrl  String?
  vendor      String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Recipe {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  category       String?
  servings       Int?
  prepTime       Int?
  cookTime       Int?
  ingredients    String   @default("[]")
  instructions   String   @default("[]")
  costPerServing Decimal  @default(0) @db.Decimal(14, 2)
  sellingPrice   Decimal  @default(0) @db.Decimal(14, 2)
  imageUrl       String?
  isPublic       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  allergenDeclarations AllergenDeclaration[]

  @@index([tenantId])
}

model Ingredient {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String?
  unit        String?
  costPerUnit Decimal  @default(0) @db.Decimal(14, 2)
  quantity    Float    @default(0)
  minStock    Float    @default(0)
  supplier    String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  allergenDeclarations AllergenDeclaration[]
  stockMovements       StockMovement[]

  @@index([tenantId])
}

model DesignItem {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  category    String?
  imageUrl    String?
  tags        String   @default("[]")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model TenantDocument {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String   @default("general")
  content   String?
  fileUrl   String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ============ SALON MODELS ============

model Appointment {
  id         String    @id @default(cuid())
  tenantId   String
  clientName String?
  stylistId  String?
  serviceId  String?
  date       DateTime?
  duration   Int       @default(60)
  status     String    @default("scheduled")
  notes      String?
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  stylist Stylist?          @relation(fields: [stylistId], references: [id])
  service SalonServiceItem? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
}

model Stylist {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  specialty String?
  phone     String?
  email     String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId])
}

model SalonServiceItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  duration    Int      @default(60)
  price       Decimal  @default(0) @db.Decimal(14, 2)
  category    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId])
}

// ============ CLINIC MODELS ============

model Patient {
  id                  String               @id @default(cuid())
  tenantId            String
  firstName           String
  lastName            String
  dateOfBirth         DateTime?
  gender              String?
  email               String?
  phone               String?
  address             String?
  bloodType           String?
  allergies           String               @default("[]")
  medicalNotes        String?
  insuranceProvider   String?
  insuranceNumber     String?
  emergencyContact    String?
  emergencyPhone      String?
  isDeleted           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  medicalAppointments MedicalAppointment[]

  @@index([tenantId])
}

model MedicalAppointment {
  id           String    @id @default(cuid())
  tenantId     String
  patientId    String?
  doctorName   String?
  specialty    String?
  date         DateTime?
  duration     Int       @default(30)
  status       String    @default("scheduled")
  notes        String?
  diagnosis    String?
  prescription String?
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  patient      Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ============ LEGAL MODELS ============

model LegalCase {
  id          String      @id @default(cuid())
  tenantId    String
  caseNumber  String?
  title       String
  clientName  String?
  caseType    String?
  status      String      @default("open")
  court       String?
  judge       String?
  openDate    DateTime?
  closeDate   DateTime?
  description String?
  billingRate Decimal     @default(0) @db.Decimal(14, 2)
  hoursBilled Float       @default(0)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  timeEntries TimeEntry[]

  @@index([tenantId])
}

model TimeEntry {
  id          String     @id @default(cuid())
  tenantId    String
  caseId      String?
  description String
  duration    Int        @default(0)
  billingRate Decimal    @default(0) @db.Decimal(14, 2)
  billable    Boolean    @default(true)
  date        DateTime?
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  legalCase   LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ============ INSURANCE MODELS ============

model Policy {
  id              String    @id @default(cuid())
  tenantId        String
  policyNumber    String?
  clientName      String?
  insuredId       String?   // FK to Insured
  productId       String?   // FK to InsuranceProduct
  agentId         String?   // FK to InsuranceAgent
  type            String    @default("property") // life, health, auto, property, travel, liability, fire, marine, other
  subType         String?   // comprehensive, third_party, etc.
  premium         Decimal   @default(0) @db.Decimal(14, 2)
  coverage        Decimal   @default(0) @db.Decimal(14, 2)
  excessAmount    Decimal   @default(0) @db.Decimal(14, 2)
  deductibleAmount Decimal  @default(0) @db.Decimal(14, 2)
  paymentFrequency String   @default("annual") // monthly, quarterly, semi_annual, annual
  startDate       DateTime?
  endDate         DateTime?
  nextPremiumDue  DateTime?
  status          String    @default("active") // active, expired, cancelled, pending, suspended, lapsed
  beneficiaries   String    @default("[]")
  notes           String?
  sumInsured      Decimal   @default(0) @db.Decimal(14, 2)
  renewalCount    Int       @default(0)
  parentPolicyId  String?
  coInsurance     Float     @default(0)
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  claims            Claim[]
  endorsements      Endorsement[]
  premiumSchedules  PremiumSchedule[]
  renewalTasks      RenewalTask[]
  insured           Insured?           @relation(fields: [insuredId], references: [id], onDelete: SetNull)
  product           InsuranceProduct?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  agent             InsuranceAgent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, policyNumber])
  @@index([tenantId, status])
}

model Claim {
  id               String    @id @default(cuid())
  tenantId         String
  policyId         String?
  claimNumber      String?
  claimantName     String?
  type             String    @default("property") // death, health, auto, property, travel, liability, fire, marine, other
  priority         String    @default("medium") // low, medium, high, critical
  amount           Decimal   @default(0) @db.Decimal(14, 2)
  reserveAmount    Decimal   @default(0) @db.Decimal(14, 2)
  settlementAmount Decimal   @default(0) @db.Decimal(14, 2)
  status           String    @default("submitted") // submitted, acknowledged, under_review, assessment, approved, denied, partially_settled, settled, closed
  decision         String?   // approved, denied, partial
  denialReason     String?
  incidentDate     DateTime?
  dateReported     DateTime  @default(now())
  dateAcknowledged DateTime?
  dateAssessed     DateTime?
  dateSettled      DateTime?
  assignedTo       String?   // adjuster name
  description      String?
  location         String?
  policeReportNumber String?
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  policy          Policy?           @relation(fields: [policyId], references: [id], onDelete: SetNull)
  documents       ClaimDocument[]
  notes           ClaimNote[]
  activities      ClaimActivity[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, claimNumber])
}

model Insured {
  id           String   @id @default(cuid())
  tenantId     String
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  dateOfBirth  String?  // Encrypted in app layer
  gender       String?
  nationalId   String?  // Encrypted in app layer
  address      String?
  city         String?
  occupation   String?
  employer     String?
  idType       String?  // national_id, passport, drivers_license
  idExpiry     String?
  notes        String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  policies Policy[]
  portalTokens PortalToken[]

  @@index([tenantId])
  @@index([tenantId, nationalId])
}

model InsuranceAgent {
  id            String   @id @default(cuid())
  tenantId      String
  agentCode     String?
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  commissionRate Decimal @default(0) @db.Decimal(5, 2) // percentage
  status        String   @default("active") // active, inactive, suspended
  joinDate      DateTime?
  address       String?
  notes         String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  policies Policy[]
  commissionStatements CommissionStatement[]

  @@index([tenantId])
  @@index([tenantId, agentCode])
}

model InsuranceProduct {
  id           String   @id @default(cuid())
  tenantId     String
  code         String?
  name         String
  category     String   @default("property") // life, health, auto, property, travel, liability, fire, marine
  description  String?
  basePremium  Decimal  @default(0) @db.Decimal(14, 2)
  minCoverage  Decimal  @default(0) @db.Decimal(14, 2)
  maxCoverage  Decimal  @default(0) @db.Decimal(14, 2)
  excessPercent Decimal @default(0) @db.Decimal(5, 2)
  deductible   Decimal  @default(0) @db.Decimal(14, 2)
  termsMonths  Int      @default(12)
  isActive     Boolean  @default(true)
  settings     String   @default("{}") // JSON for custom rules
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  policies Policy[]
  quotes   Quote[]

  @@index([tenantId])
}

model Quote {
  id                String    @id @default(cuid())
  tenantId          String
  quoteNumber       String?
  insuredName       String?
  insuredEmail      String?
  insuredPhone      String?
  productId         String?
  status            String    @default("draft") // draft, sent, accepted, declined, expired, converted
  quotedPremium     Decimal   @default(0) @db.Decimal(14, 2)
  quotedCoverage    Decimal   @default(0) @db.Decimal(14, 2)
  excessAmount      Decimal   @default(0) @db.Decimal(14, 2)
  deductibleAmount  Decimal   @default(0) @db.Decimal(14, 2)
  validUntil        DateTime?
  convertedToPolicyId String?
  notes             String?
  isDeleted         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  product           InsuranceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quoteLines        QuoteLine[]

  @@index([tenantId])
  @@index([tenantId, status])
}

