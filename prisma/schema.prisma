generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ PLATFORM MODELS ============

model PlatformUser {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  fullName      String?
  role          String   @default("tenant_admin")
  avatarUrl     String?
  isActive      Boolean  @default(true)
  hasUsedTrial  Boolean  @default(false)
  lastActiveAt  DateTime?
  country       String?
  timezone      String?
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantMemberships TenantMembership[]
  auditLogs         AuditLog[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]
}

model Plan {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  tier               String   @default("starter")
  priceUSD           Float    @default(0)
  priceTTD           Float    @default(0)
  currency           String   @default("TTD")
  billingCycle       String   @default("monthly")
  tagline            String?
  description        String?
  idealFor           String?
  maxUsers           Int      @default(3)
  maxBranches        Int      @default(1)
  features           String   @default("[]")
  excludedFeatures   String   @default("[]")
  isPopular          Boolean  @default(false)
  status             String   @default("active")
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenants      Tenant[]
  subscriptions TenantSubscription[]
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  industryId    String?
  planId        String?
  planName      String?
  status        String   @default("trial")
  trialStartsAt DateTime?
  trialEndsAt   DateTime?
  hasUsedTrial       Boolean  @default(false)
  trialDurationDays  Int      @default(7)
  approvedBy         String?
  approvedAt         DateTime?
  paymentVerified    Boolean  @default(false)
  lastActivityAt     DateTime?
  registrationIp     String?
  primaryColor  String   @default("#1D4ED8")
  accentColor   String   @default("#2563EB")
  currency      String   @default("TTD")
  timezone      String   @default("America/Port_of_Spain")
  locale        String   @default("en")
  taxRate       Float    @default(0.125)
  country       String   @default("TT")
  address       String?
  phone         String?
  email         String?
  website       String?
  settings      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  industry       Industry?         @relation(fields: [industryId], references: [id])
  plan           Plan?             @relation(fields: [planId], references: [id])
  memberships    TenantMembership[]
  orders         Order[]
  catalogItems   CatalogItem[]
  clients        Client[]
  invoices       Invoice[]
  quotations     Quotation[]
  payments       Payment[]
  expenses       Expense[]
  recipes        Recipe[]
  ingredients    Ingredient[]
  designGallery  DesignItem[]
  appointments   Appointment[]
  stylists       Stylist[]
  salonServices  SalonServiceItem[]
  subscriptions  TenantSubscription[]
  featureFlags   TenantFeatureFlag[]
  documents      TenantDocument[]
  bookkeepingEntries BookkeepingEntry[]
  auditLogs      AuditLog[]
  patients       Patient[]
  medicalAppointments MedicalAppointment[]
  legalCases     LegalCase[]
  timeEntries    TimeEntry[]
  policies       Policy[]
  claims         Claim[]
  retailProducts      RetailProduct[]
  purchaseOrders      PurchaseOrder[]
  posSales            POSSale[]
  suppliers           Supplier[]
  events         Event[]
  venues         Venue[]
  vendors        Vendor[]
  projects       Project[]
  contracts      Contract[]
  propertyUnits  PropertyUnit[]
  leases         Lease[]
  maintenanceRequests MaintenanceRequest[]
  rentPayments   RentPayment[]
  propertyDocuments PropertyDocument[]
  loyaltyMembers       LoyaltyMember[]
  loyaltyTransactions  LoyaltyTransaction[] @relation("LoyaltyTransactionTenant")
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("admin")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   PlatformUser @relation(fields: [userId], references: [id])
  tenant Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model TenantFeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  featureSlug String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureSlug])
}

model TenantSubscription {
  id              String   @id @default(cuid())
  tenantId        String
  planId          String?
  planName        String?
  status          String   @default("active")
  billingCycle    String   @default("monthly")
  priceUSD        Float    @default(0)
  priceTTD        Float    @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  paymentBehavior String   @default("always_on_time")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan?  @relation(fields: [planId], references: [id])
}

// ============ BAKERY MODELS ============

model Order {
  id              String   @id @default(cuid())
  tenantId        String
  orderNumber     String?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  items           String   @default("[]")
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("pending")
  orderType       String   @default("custom")
  deliveryDate    DateTime?
  deliveryAddress String?
  notes           String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model CatalogItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  price       Float    @default(0)
  cost        Float    @default(0)
  unit        String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  address     String?
  notes       String?
  tags        String   @default("[]")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Invoice {
  id              String   @id @default(cuid())
  tenantId        String
  invoiceNumber   String?
  clientName      String?
  clientEmail     String?
  items           String   @default("[]")
  subtotal        Float    @default(0)
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  balanceDue      Float    @default(0)
  status          String   @default("draft")
  issueDate       DateTime?
  dueDate         DateTime?
  notes           String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Quotation {
  id              String   @id @default(cuid())
  tenantId        String
  quoteNumber     String?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  items           String   @default("[]")
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("draft")
  validUntil      DateTime?
  notes           String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceId     String?
  amount        Float    @default(0)
  currency      String   @default("TTD")
  method        String   @default("cash")
  reference     String?
  status        String   @default("completed")
  notes         String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  category    String?
  description String?
  amount      Float    @default(0)
  currency    String   @default("TTD")
  date        DateTime?
  receiptUrl  String?
  vendor      String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Recipe {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  category      String?
  servings      Int?
  prepTime      Int?
  cookTime      Int?
  ingredients   String   @default("[]")
  instructions  String   @default("[]")
  costPerServing Float  @default(0)
  sellingPrice  Float   @default(0)
  imageUrl      String?
  isPublic      Boolean  @default(false)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Ingredient {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String?
  unit        String?
  costPerUnit Float    @default(0)
  quantity    Float    @default(0)
  minStock    Float    @default(0)
  supplier    String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model DesignItem {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  category    String?
  imageUrl    String?
  tags        String   @default("[]")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model TenantDocument {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String   @default("general")
  content     String?
  fileUrl     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ SALON MODELS ============

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  clientName  String?
  stylistId   String?
  serviceId   String?
  date        DateTime?
  duration    Int      @default(60)
  status      String   @default("scheduled")
  notes       String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  stylist  Stylist?  @relation(fields: [stylistId], references: [id])
  service  SalonServiceItem? @relation(fields: [serviceId], references: [id])
}

model Stylist {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  specialty   String?
  phone       String?
  email       String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]
}

model SalonServiceItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  duration    Int      @default(60)
  price       Float    @default(0)
  category    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]
}

// ============ CLINIC MODELS ============

model Patient {
  id            String   @id @default(cuid())
  tenantId      String
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  email         String?
  phone         String?
  address       String?
  bloodType     String?
  allergies     String   @default("[]")
  medicalNotes  String?
  insuranceProvider String?
  insuranceNumber   String?
  emergencyContact String?
  emergencyPhone   String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model MedicalAppointment {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String?
  doctorName  String?
  specialty   String?
  date        DateTime?
  duration    Int      @default(30)
  status      String   @default("scheduled")
  notes       String?
  diagnosis   String?
  prescription String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ LEGAL MODELS ============

model LegalCase {
  id          String   @id @default(cuid())
  tenantId    String
  caseNumber  String?
  title       String
  clientName  String?
  caseType    String?
  status      String   @default("open")
  court       String?
  judge       String?
  openDate    DateTime?
  closeDate   DateTime?
  description String?
  billingRate Float    @default(0)
  hoursBilled Float    @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model TimeEntry {
  id          String   @id @default(cuid())
  tenantId    String
  caseId      String?
  description String
  duration    Int      @default(0)
  billingRate Float    @default(0)
  billable    Boolean  @default(true)
  date        DateTime?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ INSURANCE MODELS ============

model Policy {
  id              String   @id @default(cuid())
  tenantId        String
  policyNumber    String?
  clientName      String?
  type            String?
  premium         Float    @default(0)
  coverage        Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  status          String   @default("active")
  beneficiaries   String   @default("[]")
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Claim {
  id            String   @id @default(cuid())
  tenantId      String
  policyId      String?
  claimNumber   String?
  claimantName  String?
  type          String?
  amount        Float    @default(0)
  status        String   @default("submitted")
  incidentDate  DateTime?
  description   String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ RETAIL MODELS ============

model RetailProduct {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  sku         String?
  category    String?
  price       Float    @default(0)
  cost        Float    @default(0)
  quantity    Int      @default(0)
  minStock    Int      @default(0)
  supplier    String?
  barcode     String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ PURCHASE ORDER ============

model PurchaseOrder {
  id              String    @id @default(cuid())
  tenantId        String
  poNumber        String
  supplierId      String?
  supplierName    String
  status          String    @default("draft") // draft, sent, partial, received, cancelled
  items           String    @default("[]")     // JSON: [{productId, name, sku, qty, unitCost, receivedQty}]
  totalAmount     Float     @default(0)
  receivedAmount  Float     @default(0)
  notes           String?
  expectedDate    DateTime?
  receivedAt      DateTime?
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
}

// ============ POS SALE ============

model POSSale {
  id              String    @id @default(cuid())
  tenantId        String
  saleNumber      String
  items           String    @default("[]")     // JSON: [{productId, name, sku, qty, price, cost}]
  subtotal        Float     @default(0)
  discountPct     Float     @default(0)
  discountAmount  Float     @default(0)
  taxAmount       Float     @default(0)
  totalAmount     Float     @default(0)
  paymentMethod   String    @default("cash")    // cash, card, transfer, split
  cashReceived    Float     @default(0)
  changeAmount    Float     @default(0)
  currency        String    @default("TTD")
  customerName    String    @default("")
  staffName       String?
  status          String    @default("completed") // completed, held, voided
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
}

// ============ EVENTS MODELS ============

model Event {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  type          String?
  clientName    String?
  venue         String?
  eventDate     DateTime?
  setupDate     DateTime?
  guestCount    Int      @default(0)
  budget        Float    @default(0)
  status        String   @default("planning")
  notes         String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ RETAIL SUPPLIERS ============

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  contact     String?
  email       String?
  phone       String?
  address     String?
  category    String?
  rating      Int      @default(0)
  notes       String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ EVENTS VENUES & VENDORS ============

model Venue {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  location    String?
  capacity    Int      @default(0)
  contact     String?
  email       String?
  phone       String?
  amenities   String   @default("[]")
  pricePerHour Float   @default(0)
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Vendor {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String?
  contact     String?
  email       String?
  phone       String?
  rating      Int      @default(0)
  notes       String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ PROFESSIONAL CONTRACTS ============

model Contract {
  id            String   @id @default(cuid())
  tenantId      String
  clientName    String?
  type          String?
  value         Float    @default(0)
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("active")
  description   String?
  notes         String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ PROFESSIONAL SERVICES MODELS ============

model Project {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  clientName    String?
  status        String   @default("active")
  startDate     DateTime?
  deadline      DateTime?
  budget        Float    @default(0)
  spent         Float    @default(0)
  progress      Int      @default(0)
  description   String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ LOYALTY PROGRAM ============

model LoyaltyMember {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String?
  clientName  String
  clientPhone String
  clientEmail String   @default("")
  points      Int      @default(0)
  totalSpent  Float    @default(0)
  totalOrders Int      @default(0)
  tier        String   @default("bronze")
  joinDate    DateTime @default(now())
  lastVisit   DateTime @default(now())
  createdAt   DateTime @default(now())

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  transactions LoyaltyTransaction[]

  @@unique([tenantId, clientPhone])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  memberId    String
  tenantId    String
  type        String
  points      Int
  description String   @default("")
  createdAt   DateTime @default(now())

  member LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant Tenant         @relation("LoyaltyTransactionTenant", fields: [tenantId], references: [id])
}

// ============ BOOKKEEPING ============

model BookkeepingEntry {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime
  description String
  category    String?
  type        String   @default("debit")
  amount      Float    @default(0)
  currency    String   @default("TTD")
  reference   String?
  accountId   String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ============ PLATFORM ADMIN ============

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  tenantId    String?
  action      String
  details     String?
  severity    String   @default("info")
  ipAddress   String?
  createdAt   DateTime @default(now())
  user   PlatformUser? @relation(fields: [userId], references: [id])
  tenant Tenant?       @relation(fields: [tenantId], references: [id])
}

model SystemEvent {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  severity    String   @default("info")
  tenantId    String?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
}

model PlatformInvoice {
  id            String   @id @default(cuid())
  tenantId      String?
  invoiceNumber String?
  amountUSD     Float    @default(0)
  amountTTD     Float    @default(0)
  status        String   @default("draft")
  issueDate     DateTime?
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PriceSetting {
  id        String   @id @default(cuid())
  planId    String?
  key       String   @unique
  valueUSD  Float    @default(0)
  valueTTD  Float    @default(0)
  updatedAt DateTime @updatedAt
}

// ============ LANDLORD / PROPERTY MANAGEMENT ============

model Property {
  id            String   @id @default(cuid())
  name          String
  address       String?
  city          String?
  country       String   @default("TT")
  type          String   @default("commercial") // commercial, mixed_use, office
  totalArea     Float?   // sq ft
  units         Int      @default(1)
  description   String?
  imageUrl      String?
  status        String   @default("active") // active, maintenance, inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  propertyUnits PropertyUnit[]
  maintenanceRequests MaintenanceRequest[]
  rentPayments RentPayment[]
  vendors PropertyVendor[]
  documents PropertyDocument[]
}

model PropertyUnit {
  id            String   @id @default(cuid())
  propertyId    String
  unitNumber    String   // e.g. "A1", "B2", "101"
  floor         Int      @default(1)
  area          Float?   // sq ft
  baseRentTTD   Float    @default(0)
  baseRentUSD   Float    @default(0)
  tenantId      String?  // nullable - unit can be vacant
  status        String   @default("vacant") // vacant, occupied, maintenance, reserved
  amenities     String   @default("[]")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  leases   Lease[]
  maintenanceRequests MaintenanceRequest[]
  rentPayments RentPayment[]
  documents PropertyDocument[]

  @@unique([propertyId, unitNumber])
}

model Lease {
  id                  String   @id @default(cuid())
  unitId              String
  tenantId            String?
  startDate           DateTime
  endDate             DateTime
  rentAmount          Float    @default(0)  // monthly
  rentCurrency        String   @default("TTD")
  depositAmount       Float    @default(0)
  status              String   @default("active") // draft, active, expired, terminated, renewed
  terms               String?
  notes               String?
  // Renewal fields
  autoRenew           Boolean  @default(false)
  renewalNoticeDays   Int      @default(30)       // days before end to send notice
  rentIncreasePercent Float    @default(0)         // % increase on renewal
  lastRenewedAt       DateTime?
  renewalCount        Int      @default(0)
  originalStartDate   DateTime?
  originalEndDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  unit   PropertyUnit @relation(fields: [unitId], references: [id])
  tenant Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  rentPayments RentPayment[]
  documents PropertyDocument[]
}

model MaintenanceRequest {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String?
  tenantId      String?
  title         String
  description   String?
  category      String?  // plumbing, electrical, structural, hvac, general
  priority      String   @default("medium") // low, medium, high, urgent
  status        String   @default("open") // open, in_progress, resolved, closed
  requestedAt   DateTime @default(now())
  resolvedAt    DateTime?
  cost          Float    @default(0)
  vendor        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vendorId String?

  propertyVendor PropertyVendor? @relation(fields: [vendorId], references: [id])
}

// ============ PREMIUM LANDLORD FEATURES ============

model RentPayment {
  id            String   @id @default(cuid())
  leaseId       String
  propertyId    String
  unitId        String
  tenantId      String?
  periodStart   DateTime  // billing period start
  periodEnd     DateTime  // billing period end
  amountDue     Float    @default(0)
  amountPaid    Float    @default(0)
  lateFee       Float    @default(0)
  currency      String   @default("TTD")
  paymentMethod String?  // bank_transfer, cash, cheque, online
  paymentRef    String?
  status        String   @default("pending") // pending, partial, paid, late, overdue
  paidAt        DateTime?
  dueDate       DateTime
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lease     Lease        @relation(fields: [leaseId], references: [id])
  property  Property     @relation(fields: [propertyId], references: [id])
  unit      PropertyUnit @relation(fields: [unitId], references: [id])
  tenant    Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model PropertyVendor {
  id          String   @id @default(cuid())
  propertyId  String?
  name        String
  category    String?  // plumbing, electrical, hvac, cleaning, landscaping, general, security, pest
  contact     String?
  email       String?
  phone       String?
  address     String?
  rating      Int      @default(0) // 1-5
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])
  maintenanceRequests MaintenanceRequest[]
}

model PropertyDocument {
  id          String   @id @default(cuid())
  propertyId  String?
  unitId      String?
  leaseId     String?
  tenantId    String?
  name        String
  type        String   @default("other") // lease_agreement, insurance, inspection, invoice, receipt, tax_doc, certificate, other
  category    String?
  fileUrl     String?
  description String?
  expiresAt   DateTime?
  status      String   @default("active") // active, expired, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property Property?    @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  lease    Lease?        @relation(fields: [leaseId], references: [id])
  tenant   Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model JournalEntry {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  reference   String?
  status      String   @default("posted") // draft, posted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalEntryLine[]
}

model JournalEntryLine {
  id               String   @id @default(cuid())
  journalEntryId   String
  accountCode      String
  accountName      String
  accountType      String   // Asset, Liability, Equity, Revenue, Expense
  debit            Float    @default(0)
  credit           Float    @default(0)
  createdAt        DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
}

// ============ OWNER / INVESTOR REPORTING ============

model OwnerDisbursement {
  id            String   @id @default(cuid())
  propertyId    String?
  periodStart   DateTime
  periodEnd     DateTime
  grossIncome   Float    @default(0)
  totalExpenses Float    @default(0)
  netIncome     Float    @default(0)
  ownerShare    Float    @default(100) // percentage
  disbursementAmount Float @default(0)
  currency      String   @default("TTD")
  status        String   @default("pending") // pending, approved, paid
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LeaseRenewalLog {
  id            String   @id @default(cuid())
  leaseId       String
  previousEnd   DateTime
  newStart      DateTime
  newEnd        DateTime
  oldRent       Float    @default(0)
  newRent       Float    @default(0)
  increasePct   Float    @default(0)
  renewedBy     String?  // userId or 'auto'
  notes         String?
  createdAt     DateTime @default(now())
}
