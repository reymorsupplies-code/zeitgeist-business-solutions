# ============================================
# ZBS — Supabase PostgreSQL (PRISMA)
# ============================================
# Obtén estos datos en: Supabase Dashboard → Settings → Database
#   → Connection string → URI (usa la versión "Transaction pooler")
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ============================================
# ZBS — Supabase Client (NEXT.js)
# ============================================
# Obtén estos datos en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"
SUPABASE_ACCESS_TOKEN="[ACCESS-TOKEN]"

# ============================================
# ZBS — Auth (JWT)
# ============================================
JWT_SECRET="HjjBAJfp9u16V5jBB7nm7Ns7APyIuF9fkN1D8SWCBtE="
NEXTAUTH_SECRET="HjjBAJfp9u16V5jBB7nm7Ns7APyIuF9fkN1D8SWCBtE="
